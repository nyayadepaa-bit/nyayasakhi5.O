# ── NyayaDepaaAI Auth Backend — Environment Variables ──

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# Extra CORS origins (comma-separated). Add your Vercel domain(s) here.
# Example: ALLOWED_ORIGINS=https://nyayadepaaai.vercel.app,https://www.nyayadepaaai.com
ALLOWED_ORIGINS=

# (All other config has defaults in config.py — override here as needed)
# DATABASE_URL=postgresql+asyncpg://...
# JWT_SECRET_KEY=your-secret
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-admin-password
